{
  "version": 2,
  "builds": [
    {
      "src": "bookease-app/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "bookease-backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "bookease-backend/server.js"
    },
    { "handle": "filesystem" },
    {
      "src": "/assets/(.*)",
      "dest": "/bookease-app/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/bookease-app/index.html"
    }
  ]
}